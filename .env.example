NODE_ENV=development
PORT=4000

# WAQI key stays server-side only. Do not place this value in frontend code.
WAQI_API_KEY=

# Optional supplementary observed AQ validation. Keep server-side only.
OPENAQ_API_KEY=

# NASA FIRMS fire/hotspot source. Request a free MAP_KEY from NASA FIRMS.
NASA_FIRMS_MAP_KEY=
FIRMS_SOURCE=VIIRS_SNPP_NRT
FIRMS_KOGI_BBOX=5.3,6.4,7.9,8.8

# Local development CORS. Replace with the Vercel domain after deployment.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# KSEIP study coordinates.
LOKOJA_LAT=7.80
LOKOJA_LON=6.74
OBAJANA_LAT=7.50
OBAJANA_LON=6.32
ANYIGBA_LAT=7.48
ANYIGBA_LON=6.90

# Polling and cache controls from the blueprint.
WAQI_POLL_MINUTES=60
OPEN_METEO_REFRESH_HOURS=3
AQI_CACHE_HOURS=24
CLIMATE_CACHE_DAYS=30
WAQI_DAILY_LIMIT=1000
